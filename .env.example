# Postgres (used by docker-compose to provision the db service)
POSTGRES_USER=attendance_api
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=attendance_api

# Attendance API database (separate from the auth database).
# For local (non-Docker) dev point this at your own Postgres instance.
DATABASE_URL=postgresql://attendance_api:change-me-strong-password@localhost:5433/attendance_api?schema=public

# MUST match the JWT_SECRET of the attendance-auth service.
# This API only verifies tokens; it never issues them.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Issuer claim expected on incoming access tokens (attendance-auth sets this).
JWT_ISSUER=attendance-auth

# HTTP port the API listens on
PORT=4000

# Host port the API is exposed on (docker-compose)
API_PORT=4000
